# ─────────────────────────────────────────────────────────────────────────
# TELC Simulator Pro — variables d'environnement
# Copiez ce fichier en `.env` (dev) et/ou renseignez-les dans Vercel (prod).
# Ne committez JAMAIS de vraies clés — ce fichier ne contient que des exemples.
# ─────────────────────────────────────────────────────────────────────────

# ── Base de données (Supabase Postgres, pooler recommandé) ────────────────
DATABASE_URL="postgresql://postgres:MOT_DE_PASSE@db.xxxx.supabase.co:5432/postgres?sslmode=require"

# ── Authentification (NextAuth v5) ────────────────────────────────────────
# Générer : `openssl rand -base64 32`
AUTH_SECRET="remplacez-par-un-secret-aleatoire"

# ── Connexion Google (OAuth) ──────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID
# (type « Web application »). Redirect URI autorisé :
#   https://VOTRE-DOMAINE/api/auth/callback/google
#   (en dev : http://localhost:3000/api/auth/callback/google)
# Sans ces deux clés, le bouton « Mit Google » est inactif.
AUTH_GOOGLE_ID="xxxxxxxx.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="GOCSPX-xxxxxxxx"

# ── Supabase Storage (upload audio Hören) ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="votre-cle-anon-publique"

# ── E-mail : vérification d'adresse (Resend) ──────────────────────────────
# Sans RESEND_API_KEY, le lien de vérification est seulement journalisé
# (les nouveaux comptes ne peuvent alors pas se connecter).
RESEND_API_KEY="re_xxxxxxxx"
EMAIL_FROM="TELC Simulator Pro <no-reply@votre-domaine.tld>"

# ── Paiements : Stripe (cartes, monde entier) ─────────────────────────────
STRIPE_SECRET_KEY="sk_test_xxxxxxxx"
# Webhook : https://VOTRE-DOMAINE/api/payments/stripe/webhook
# Événement : checkout.session.completed → copiez le "Signing secret" ici.
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxx"

# ── Paiements : Flutterwave (Mobile Money Afrique / Cameroun, cartes) ──────
FLW_SECRET_KEY="FLWSECK_TEST-xxxxxxxx"
# Webhook : https://VOTRE-DOMAINE/api/payments/flutterwave/webhook
# "Secret hash" (vous le choisissez chez Flutterwave, identique ici).
FLW_SECRET_HASH="un-secret-de-webhook-que-vous-choisissez"

# ── Génération de contenu (audio Hören via ElevenLabs) — optionnel ────────
ELEVENLABS_API_KEY="sk_elevenlabs_xxxxxxxx"
# Modèle et voix (valeurs par défaut raisonnables si omis).
ELEVENLABS_MODEL="eleven_multilingual_v2"
ELEVENLABS_VOICES="voix1,voix2,voix3"
