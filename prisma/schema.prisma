// Modèle de données TELC Simulator Pro — conforme à ARCHITECTURE.md §4.
// La STRUCTURE officielle telc vit dans src/config/exam-structure.ts ;
// la base ne stocke que le CONTENU et les sessions.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Prisma 7 : l'URL de connexion vit dans prisma.config.ts (migrations)
  // et dans le driver adapter passé à PrismaClient (src/lib/db.ts).
}

enum Role {
  STUDENT
  CENTER_ADMIN
  SUPER_ADMIN
}

enum Plan {
  FREE
  STUDENT
  CENTER
  PREMIUM
}

enum Level {
  B1
  B2
}

enum QuestionType {
  TITLE_MATCHING
  MULTIPLE_CHOICE
  AD_MATCHING
  CLOZE_DROPDOWN
  WRITING
}

enum SessionStatus {
  AUDIO_CHECK
  IN_PROGRESS
  SUBMITTED
  EXPIRED
  SCORED
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  // Null pour les comptes créés via Google (OAuth) : pas de mot de passe local.
  passwordHash String?
  name         String
  // Numéro de téléphone (WhatsApp) saisi à l'inscription — sert au paiement
  // et au contact. Null pour les comptes Google tant qu'il n'est pas renseigné.
  phone        String?
  role         Role          @default(STUDENT)
  plan         Plan          @default(FREE)
  // Date de vérification de l'e-mail — null tant que non vérifié (la
  // connexion est refusée dans ce cas).
  emailVerified DateTime?
  // Fin de validité du plan payant (abonnement) — null pour FREE.
  planExpiresAt DateTime?
  // Crédits de passage d'examen (anti-partage). 1 crédit = 1 examen, débité
  // au démarrage du chrono. Rechargés à chaque paiement (config/credits.ts).
  // Pour un étudiant de centre, le pool consommé est celui du propriétaire.
  credits      Int           @default(2)
  // Rattachement à un centre de langue en tant qu'ÉTUDIANT membre.
  centerId     String?
  center       Center?       @relation("CenterMembers", fields: [centerId], references: [id])
  // Centre géré par cet utilisateur (rôle CENTER_ADMIN) — au plus un.
  ownedCenter  Center?       @relation("CenterOwner")
  sessions     ExamSession[]
  payments     Payment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([centerId])
}

/**
 * Centre de langue : un compte CENTER_ADMIN (owner) gère des étudiants
 * (members). Les étudiants rejoignent via un lien contenant `inviteCode`
 * (la « clé »). Le nombre de places (`seats`) est acheté au quota d'élèves.
 */
model Center {
  id         String   @id @default(cuid())
  name       String
  ownerId    String   @unique
  owner      User     @relation("CenterOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  // Clé d'invitation (partagée via le lien /join/<inviteCode>).
  inviteCode String   @unique
  // Quota d'étudiants acheté.
  seats      Int      @default(0)
  members    User[]   @relation("CenterMembers")
  createdAt  DateTime @default(now())
}

/** Jeton de vérification d'e-mail (haché) — usage unique, borné dans le temps. */
model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

enum PaymentProvider {
  FLUTTERWAVE
  STRIPE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

/** Trace d'un paiement (init → webhook). L'activation du plan est idempotente. */
model Payment {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    PaymentProvider
  // tx_ref (Flutterwave) ou id de session Checkout (Stripe).
  providerRef String          @unique
  plan        Plan
  amount      Float
  currency    String
  // Places achetées (paiement CENTER par quota) — null pour Student/Premium.
  seats       Int?
  status      PaymentStatus   @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId])
}

model Exam {
  id          String        @id @default(cuid())
  title       String
  level       Level
  isPublished Boolean       @default(false)
  parts       ExamPart[]
  sessions    ExamSession[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ExamPart {
  id        String     @id @default(cuid())
  examId    String
  exam      Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  // Références vers la structure officielle (config/exam-structure.ts).
  sectionId String // "lesen" | "hoeren" | "sprachbausteine" | "schreiben"
  partId    String // "teil-1" | "teil-2" | "teil-3" | "aufgabe-a" | "aufgabe-b"
  // Contenu partagé du Teil : texte(s) source, banque des 10 titres,
  // annonces A–L, texte à trous… Forme validée par Zod selon le type
  // (src/types/question-content.ts).
  sharedContent Json?
  // Hören uniquement.
  audioUrl  String?
  questions Question[]

  @@unique([examId, sectionId, partId])
}

model Question {
  id       String       @id @default(cuid())
  partId   String
  part     ExamPart     @relation(fields: [partId], references: [id], onDelete: Cascade)
  position Int
  type     QuestionType
  // Structure validée par Zod selon `type` (src/types/question-content.ts).
  content  Json
  // Correction automatique — null pour WRITING (correction manuelle v1).
  answerKey Json?
  points   Float
  answers  Answer[]

  @@unique([partId, position])
}

model ExamSession {
  id     String        @id @default(cuid())
  userId String
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  examId String
  exam   Exam          @relation(fields: [examId], references: [id])
  status SessionStatus @default(AUDIO_CHECK)
  // Ancre du timer — posée une seule fois, JAMAIS modifiée ensuite.
  // Fondement du timer inviolable (ARCHITECTURE.md §6).
  startedAt   DateTime?
  submittedAt DateTime?
  // Ids des audios déjà consommés (marqués dès `play`).
  audioPlayed Json      @default("[]")
  answers     Answer[]
  result      Result?
  createdAt   DateTime  @default(now())
}

model Answer {
  id         String      @id @default(cuid())
  sessionId  String
  session    ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId String
  question   Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  // string (choix / texte libre) ou null — voir types/session.ts.
  value     Json
  updatedAt DateTime @updatedAt

  // L'autosave est un simple upsert idempotent.
  @@unique([sessionId, questionId])
}

model Result {
  id          String      @id @default(cuid())
  sessionId   String      @unique
  session     ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  totalPoints Float
  maxPoints   Float
  // Détail par section/Teil (calculé par lib/scoring, Sprint 8).
  sectionScores Json
  // null tant que le Schreiben n'est pas corrigé (correction manuelle v1).
  passed    Boolean?
  createdAt DateTime @default(now())
}
